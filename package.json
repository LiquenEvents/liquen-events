{
  "name": "liquen-events",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gen:blur": "node scripts/gen-blur.mjs",
    "gen:dims": "node scripts/gen-image-dims.mjs",
    "gen:totp": "node scripts/gen-totp.mjs",
    "analyze": "ANALYZE=true next build",
    "compress:images": "node scripts/compress-sources.mjs",
    "upload:images": "node scripts/upload-images-to-supabase.mjs",
    "warm:cache": "node scripts/warm-image-cache.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "imapflow": "^1.4.7",
    "mailparser": "^3.9.14",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.3",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.60.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "typescript": "^7",
    "vitest": "^4.1.7"
  }
}
